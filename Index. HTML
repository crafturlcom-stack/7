<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<title>Dino Mobile</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        touch-action: manipulation;
        user-select:none;
    }

    body{
        background:#f5f5f5;
        overflow:hidden;
        font-family:Arial, sans-serif;
    }

    #game{
        position:relative;
        width:100vw;
        height:100vh;
        overflow:hidden;
        background:white;
    }

    #ground{
        position:absolute;
        bottom:100px;
        width:100%;
        height:4px;
        background:black;
    }

    #dino{
        position:absolute;
        width:60px;
        height:60px;
        left:60px;
        bottom:104px;
        font-size:55px;
    }

    .cactus{
        position:absolute;
        bottom:104px;
        width:35px;
        height:60px;
        font-size:50px;
    }

    #score{
        position:absolute;
        top:20px;
        right:20px;
        font-size:30px;
        font-weight:bold;
    }

    #gameOver{
        position:absolute;
        top:40%;
        width:100%;
        text-align:center;
        font-size:40px;
        display:none;
    }

    #restart{
        margin-top:20px;
        padding:15px 30px;
        font-size:25px;
        border:none;
        background:black;
        color:white;
        border-radius:10px;
    }

    #controls{
        position:absolute;
        bottom:10px;
        width:100%;
        display:flex;
        justify-content:center;
        gap:20px;
    }

    .btn{
        width:120px;
        height:70px;
        border:none;
        border-radius:15px;
        font-size:28px;
        background:black;
        color:white;
    }
</style>
</head>

<body>

<div id="game">

    <div id="score">0</div>

    <div id="dino">🦖</div>

    <div id="ground"></div>

    <div id="gameOver">
        ИГРА ОКОНЧЕНА
        <br>
        <button id="restart">ЗАНОВО</button>
    </div>

    <div id="controls">
        <button class="btn" id="jumpBtn">⬆</button>
        <button class="btn" id="duckBtn">⬇</button>
    </div>

</div>

<script>
const dino = document.getElementById("dino");
const game = document.getElementById("game");
const scoreText = document.getElementById("score");
const gameOver = document.getElementById("gameOver");
const restartBtn = document.getElementById("restart");

let jumping = false;
let ducking = false;
let gameEnded = false;

let score = 0;
let dinoBottom = 104;

const MAX_SCORE = 99999;

function jump(){
    if(jumping || gameEnded) return;

    jumping = true;

    let upInterval = setInterval(() => {

        if(dinoBottom >= 280){
            clearInterval(upInterval);

            let downInterval = setInterval(() => {

                if(dinoBottom <= 104){
                    clearInterval(downInterval);
                    jumping = false;
                }

                dinoBottom -= 8;
                dino.style.bottom = dinoBottom + "px";

            },20);
        }

        dinoBottom += 8;
        dino.style.bottom = dinoBottom + "px";

    },20);
}

function duck(enable){
    if(gameEnded) return;

    if(enable){
        dino.style.transform = "scaleY(0.5)";
        dino.style.transformOrigin = "bottom";
    }else{
        dino.style.transform = "scaleY(1)";
    }
}

document.getElementById("jumpBtn").addEventListener("touchstart", jump);
document.getElementById("jumpBtn").addEventListener("click", jump);

document.getElementById("duckBtn").addEventListener("touchstart", () => duck(true));
document.getElementById("duckBtn").addEventListener("touchend", () => duck(false));

document.getElementById("duckBtn").addEventListener("mousedown", () => duck(true));
document.getElementById("duckBtn").addEventListener("mouseup", () => duck(false));

function createCactus(){

    if(gameEnded) return;

    const cactus = document.createElement("div");
    cactus.classList.add("cactus");
    cactus.innerHTML = "🌵";

    let cactusLeft = window.innerWidth;

    cactus.style.left = cactusLeft + "px";

    game.appendChild(cactus);

    let speed = 10;

    const move = setInterval(() => {

        if(gameEnded){
            clearInterval(move);
            cactus.remove();
            return;
        }

        cactusLeft -= speed;
        cactus.style.left = cactusLeft + "px";

        const dinoLeft = 60;
        const dinoRight = 120;

        const cactusRight = cactusLeft + 35;

        if(
            cactusRight > dinoLeft &&
            cactusLeft < dinoRight &&
            dinoBottom < 160
        ){
            endGame();
        }

        if(cactusLeft < -50){
            clearInterval(move);
            cactus.remove();

            if(score < MAX_SCORE){
                score++;
                scoreText.innerText = score;
            }
        }

    },20);

    let randomTime = Math.random() * 2000 + 1200;

    if(!gameEnded){
        setTimeout(createCactus, randomTime);
    }
}

function endGame(){
    gameEnded = true;
    gameOver.style.display = "block";
}

restartBtn.addEventListener("click", () => {
    location.reload();
});

createCactus();
</script>

</body>
</html>